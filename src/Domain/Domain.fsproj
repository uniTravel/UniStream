<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>netcoreapp3.0</TargetFramework>
    <AssemblyName>UniStream.Domain</AssemblyName>
    <Version>0.0.1</Version>
    <Authors>Eric</Authors>
    <Company>UniCloud</Company>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="AssemblyInfo.fs" />
    <Compile Include="IDomain.fsi" />
    <Compile Include="IDomain.fs" />
    <Compile Include="MetaTrace.fsi" />
    <Compile Include="MetaTrace.fs" />
    <Compile Include="LogType.fsi" />
    <Compile Include="LogType.fs" />
    <Compile Include="DomainLog.fsi" />
    <Compile Include="DomainLog.fs" />
    <Compile Include="DiagnoseLog.fsi" />
    <Compile Include="DiagnoseLog.fs" />
    <Compile Include="DomainEvent.fsi" />
    <Compile Include="DomainEvent.fs" />
    <Compile Include="DomainCommand.fsi" />
    <Compile Include="DomainCommand.fs" />
    <Compile Include="Repository.fsi" />
    <Compile Include="Repository.fs" />
    <Compile Include="Aggregate.fsi" />
    <Compile Include="Aggregate.fs" />
    <Compile Include="Note.fs" />
    <None Include="paket.references" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Infrastructure\Infrastructure.fsproj" />
  </ItemGroup>
  <Import Project="..\..\.paket\Paket.Restore.targets" />
</Project>