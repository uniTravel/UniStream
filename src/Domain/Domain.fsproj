<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net5.0</TargetFramework>
    <AssemblyName>UniStream.Domain</AssemblyName>
    <Version>1.0.0</Version>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>
  <ItemGroup Condition=" '$(Configuration)' == 'Debug' ">
    <InternalsVisibleTo Include="Domain.Tests"/>
  </ItemGroup>
  <ItemGroup>
    <Compile Include="Exceptions.fs" />
    <Compile Include="Delta.fsi" />
    <Compile Include="Delta.fs" />
    <Compile Include="Command.fsi" />
    <Compile Include="Command.fs" />
    <Compile Include="Config.fsi" />
    <Compile Include="Config.fs" />
    <Compile Include="Factory.fsi" />
    <Compile Include="Factory.fs" />
    <Compile Include="Immutable.fsi" />
    <Compile Include="Immutable.fs" />
    <Compile Include="Mutable.fsi" />
    <Compile Include="Mutable.fs" />
    <Compile Include="Observer.fsi" />
    <Compile Include="Observer.fs" />
  </ItemGroup>
</Project>